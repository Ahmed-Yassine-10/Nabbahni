# ─────────────────────────────────────────────────────────────
# SentinelleRx — environment configuration (copy to .env)
# ─────────────────────────────────────────────────────────────

# ---- Core ----
ENVIRONMENT=development
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
LOG_LEVEL=INFO

# ---- PostgreSQL / PostGIS ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=sentinelle
POSTGRES_PASSWORD=sentinelle_dev_pw
POSTGRES_DB=sentinellerx
# SQLAlchemy async URL (built by settings if left blank)
DATABASE_URL=postgresql+psycopg://sentinelle:sentinelle_dev_pw@localhost:5432/sentinellerx

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=60

# ---- RabbitMQ ----
RABBITMQ_URL=amqp://sentinelle:sentinelle_dev_pw@localhost:5672/
RABBITMQ_INGEST_EXCHANGE=ingest.events
RABBITMQ_ALERTS_EXCHANGE=alerts.fanout

# ---- Keycloak (OIDC) ----
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=sentinellerx
KEYCLOAK_API_CLIENT_ID=sentinellerx-api
KEYCLOAK_WEB_CLIENT_ID=sentinellerx-web
# Set to true only once Keycloak is running; false lets the API run with a
# local dev-token fallback for testing without Keycloak.
KEYCLOAK_ENABLED=false

# ---- MinIO / S3 ----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=sentinelle
S3_SECRET_KEY=sentinelle_dev_pw
S3_BUCKET=sentinellerx
S3_REGION=us-east-1

# ---- Qdrant ----
QDRANT_URL=http://localhost:6333

# ---- MLflow ----
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000

# ---- Observability ----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=sentinellerx-api
SENTRY_DSN=
PROMETHEUS_ENABLED=true

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_LOCALE=fr
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-frontend-secret
AUTH_KEYCLOAK_ID=sentinellerx-web
AUTH_KEYCLOAK_SECRET=sentinellerx-web-secret
AUTH_KEYCLOAK_ISSUER=http://localhost:8081/realms/sentinellerx
